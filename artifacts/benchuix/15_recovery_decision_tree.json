    "runtime",
    "tenant",
    "CI",
    "active-context"
  ],
  "blocking_criteria": [
    "promessa de desfazer irreversivel",
    "compensacao chamada de reversao",
    "rollback duplicavel",
    "rollback sem limite",
    "razao de impacto ausente",
    "evidencia vendida como prova real",
    "qualquer acao, mutacao, dado ou servico real no escopo"
