{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ARIS Active Context Canonical Live State Schema v2.1",
  "description": "Structural evolutionary validation contract for ACTIVE_CONTEXT_STATE.json. Const retained only for permanent invariants. Phase names, status strings, and mutable flags use type/enum/required constraints. Markdown files are derived mirrors only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "active_context_version",
    "schema_version",
    "canonical_repository",
    "canonical_branch",
    "canonical_live_state_file",
    "canonical_schema_file",
    "markdown_files_are",
    "additional_live_state_sources_allowed",
    "status",
    "decision",
    "latest_completed_phase",
    "current_status",
    "active_next_phase",
    "active_next_phase_class",
    "versioning_contract",
    "anti_corruption_contract",
    "artifact_integrity_policy",
    "cross_field_consistency_policy",
    "required_files_for_transition",
    "completed_phases",
    "current_live_route",
    "next_action",
    "locks",
    "authorization",
    "canonicality_rules",
    "validation_policy",
    "artifact_routes",
    "history_summary",
    "last_transition",
    "required_update_policy",
    "drift_signals"
  ],
  "properties": {
    "active_context_version": {
      "type": "string",
      "enum": ["2.0", "2.1"]
    },
    "schema_version": {
      "type": "string",
      "enum": ["2.1"]
    },
    "canonical_repository": {
      "type": "string",
      "const": "MatheusAugDEV/aris-active-context"
    },
    "canonical_branch": {
      "type": "string",
      "const": "main"
    },
    "canonical_live_state_file": {
      "type": "string",
      "const": "ACTIVE_CONTEXT_STATE.json"
    },
    "canonical_schema_file": {
      "type": "string",
      "const": "ACTIVE_CONTEXT_SCHEMA.json"
    },
    "markdown_files_are": {
      "type": "string"
    },
    "additional_live_state_sources_allowed": {
      "type": "boolean",
      "const": false
    },
    "status": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": ["pass", "fail", "blocked", "warn"]
    },
    "latest_completed_phase": {
      "type": "string"
    },
    "current_status": {
      "type": "string"
    },
    "active_next_phase": {
      "type": "string"
    },
    "active_next_phase_class": {
      "type": "string",
      "enum": [
        "review_gate_only",
        "planning_gate",
        "readiness_gate",
        "normalization_gate",
        "governance_repair_gate",
        "history_only"
      ]
    },
    "versioning_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active_context_version_meaning",
        "schema_version_meaning",
        "current_active_context_version",
        "current_schema_version",
        "increment_schema_version_when",
        "increment_active_context_version_when"
      ],
      "properties": {
        "active_context_version_meaning": { "type": "string" },
        "schema_version_meaning": { "type": "string" },
        "current_active_context_version": { "type": "string" },
        "current_schema_version": { "type": "string" },
        "schema_2_1_change_summary": { "type": "string" },
        "increment_schema_version_when": { "type": "string" },
        "increment_active_context_version_when": { "type": "string" }
      }
    },
    "anti_corruption_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_read_order",
        "json_beats_markdown",
        "markdown_conflict_policy",
        "validator_must_pass_before_any_decision",
        "agent_must_read_json_before_markdown",
        "anti_corruption_contract_file",
        "violation_response"
      ],
      "properties": {
        "canonical_read_order": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 3
        },
        "json_beats_markdown": { "type": "boolean", "const": true },
        "markdown_conflict_policy": { "type": "string" },
        "validator_must_pass_before_any_decision": { "type": "boolean", "const": true },
        "agent_must_read_json_before_markdown": { "type": "boolean", "const": true },
        "anti_corruption_contract_file": { "type": "string" },
        "violation_response": { "type": "string" }
      }
    },
    "artifact_integrity_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "missing_artifact_handling",
        "allowed_classifications",
        "artifact_routes_existence_check",
        "context_index_classification_required",
        "unclassified_missing_artifact_policy"
      ],
      "properties": {
        "missing_artifact_handling": { "type": "string" },
        "allowed_classifications": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "classified_artifact_prefixes": {
          "type": "object"
        },
        "artifact_routes_existence_check": { "type": "boolean" },
        "context_index_classification_required": { "type": "boolean" },
        "unclassified_missing_artifact_policy": { "type": "string" }
      }
    },
    "cross_field_consistency_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active_next_phase_must_match_across",
        "latest_completed_phase_must_match_across",
        "status_must_match_across",
        "current_status_must_match_across",
        "enforcement"
      ],
      "properties": {
        "active_next_phase_must_match_across": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 2
        },
        "latest_completed_phase_must_match_across": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 2
        },
        "status_must_match_across": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 2
        },
        "current_status_must_match_across": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 2
        },
        "enforcement": { "type": "string" },
        "exception_field": { "type": "string" }
      }
    },
    "required_files_for_transition": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 15,
      "uniqueItems": true
    },
    "completed_phases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["phase", "decision", "status"],
        "properties": {
          "phase": { "type": "string" },
          "decision": { "type": "string", "enum": ["pass"] },
          "status": { "type": "string" },
          "repair_type": { "type": "string" }
        }
      },
      "minItems": 1
    },
    "current_live_route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "decision",
        "latest_completed_phase",
        "current_status",
        "active_next_phase",
        "active_next_phase_class",
        "next_phase_execution_authorization",
        "operator_approval_packet_review_is_execution_approval",
        "h4_h5_hx_active_current_route"
      ],
      "properties": {
        "status": { "type": "string" },
        "decision": { "type": "string", "enum": ["pass", "fail", "blocked", "warn"] },
        "latest_completed_phase": { "type": "string" },
        "current_status": { "type": "string" },
        "active_next_phase": { "type": "string" },
        "active_next_phase_class": {
          "type": "string",
          "enum": [
            "review_gate_only",
            "planning_gate",
            "readiness_gate",
            "normalization_gate",
            "governance_repair_gate",
            "history_only"
          ]
        },
        "next_phase_execution_authorization": { "type": "boolean" },
        "operator_approval_packet_review_is_execution_approval": { "type": "boolean" },
        "h4_h5_hx_active_current_route": { "type": "boolean" }
      }
    },
    "next_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase",
        "phase_class",
        "planning_only",
        "status",
        "review_only",
        "execution_authorization",
        "operator_approval_packet_review_is_execution_approval",
        "notes"
      ],
      "properties": {
        "phase": { "type": "string" },
        "phase_class": {
          "type": "string",
          "enum": [
            "review_gate_only",
            "planning_gate",
            "readiness_gate",
            "normalization_gate",
            "governance_repair_gate",
            "history_only"
          ]
        },
        "planning_only": { "type": "boolean" },
        "status": { "type": "string" },
        "review_only": { "type": "boolean" },
        "execution_authorization": { "type": "boolean" },
        "operator_approval_packet_review_is_execution_approval": { "type": "boolean" },
        "notes": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },
    "locks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_source",
        "canonical_live_state_file",
        "canonical_schema_file",
        "markdown_files_are",
        "github_active_context_is_the_only_canonical_active_context_source",
        "no_github_active_context_sync_no_canonical_pass",
        "every_transition_must_update_commit_push_and_verify_github_active_context",
        "stale_live_route_policy",
        "markdown_mirror_drift_policy",
        "h4_h5_hx_active_current_route",
        "deferred_phase",
        "deferred_phase_reason"
      ],
      "properties": {
        "canonical_source": { "type": "string" },
        "canonical_live_state_file": { "type": "string", "const": "ACTIVE_CONTEXT_STATE.json" },
        "canonical_schema_file": { "type": "string", "const": "ACTIVE_CONTEXT_SCHEMA.json" },
        "markdown_files_are": { "type": "string" },
        "github_active_context_is_the_only_canonical_active_context_source": { "type": "boolean", "const": true },
        "no_github_active_context_sync_no_canonical_pass": { "type": "boolean", "const": true },
        "every_transition_must_update_commit_push_and_verify_github_active_context": { "type": "boolean", "const": true },
        "stale_live_route_policy": { "type": "string" },
        "markdown_mirror_drift_policy": { "type": "string" },
        "h4_h5_hx_active_current_route": { "type": "boolean" },
        "deferred_phase": { "type": "string" },
        "deferred_phase_reason": { "type": "string" }
      }
    },
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "production_authorized",
        "product_ready",
        "runtime_integration_allowed",
        "generic_action_runtime_activated",
        "real_apply_authorized",
        "real_dry_run_execution_authorized",
        "approval_execution_authorized",
        "runtime_refactor_authorized",
        "host_filesystem_mutation_authorized",
        "debian_harness_execution_authorized",
        "container_image_vm_creation_authorized",
        "package_manager_execution_authorized",
        "package_installation_authorized",
        "network_authorized_scope",
        "secrets_access_authorized",
        "external_llm_api_authorized",
        "dependency_change_authorized",
        "frontend_backend_action_runtime_audio_mutation_authorized"
      ],
      "properties": {
        "production_authorized": { "type": "boolean" },
        "product_ready": { "type": "boolean" },
        "runtime_integration_allowed": { "type": "boolean" },
        "generic_action_runtime_activated": { "type": "boolean" },
        "real_apply_authorized": { "type": "boolean" },
        "real_dry_run_execution_authorized": { "type": "boolean" },
        "approval_execution_authorized": { "type": "boolean" },
        "runtime_refactor_authorized": { "type": "boolean" },
        "host_filesystem_mutation_authorized": { "type": "boolean" },
        "debian_harness_execution_authorized": { "type": "boolean" },
        "container_image_vm_creation_authorized": { "type": "boolean" },
        "package_manager_execution_authorized": { "type": "boolean" },
        "package_installation_authorized": { "type": "boolean" },
        "network_authorized_scope": { "type": "string" },
        "secrets_access_authorized": { "type": "boolean" },
        "external_llm_api_authorized": { "type": "boolean" },
        "dependency_change_authorized": { "type": "boolean" },
        "frontend_backend_action_runtime_audio_mutation_authorized": { "type": "boolean" }
      }
    },
    "canonicality_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "github_active_context_is_the_only_canonical_active_context_source",
        "canonical_repository",
        "canonical_branch",
        "canonical_live_state_file",
        "canonical_schema_file",
        "local_checkout_is_non_canonical_until_remote_verified",
        "no_local_only_update_is_canonical",
        "no_unpushed_commit_is_canonical",
        "no_github_sync_no_canonical_pass",
        "markdown_files_are_derived_mirrors_or_history_not_authoritative_live_state"
      ],
      "properties": {
        "canonical_repository": { "type": "string", "const": "MatheusAugDEV/aris-active-context" },
        "canonical_branch": { "type": "string", "const": "main" },
        "canonical_live_state_file": { "type": "string", "const": "ACTIVE_CONTEXT_STATE.json" },
        "canonical_schema_file": { "type": "string", "const": "ACTIVE_CONTEXT_SCHEMA.json" },
        "github_active_context_is_the_only_canonical_active_context_source": { "type": "boolean", "const": true },
        "local_checkout_is_non_canonical_until_remote_verified": { "type": "boolean", "const": true },
        "markdown_files_are_derived_mirrors_or_history_not_authoritative_live_state": { "type": "boolean", "const": true },
        "no_github_sync_no_canonical_pass": { "type": "boolean", "const": true },
        "no_local_only_update_is_canonical": { "type": "boolean", "const": true },
        "no_unpushed_commit_is_canonical": { "type": "boolean", "const": true }
      }
    },
    "validation_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "json_validation_commands",
        "required_validator",
        "connector_fallback_allowed",
        "markdown_mirror_validation_required",
        "fail_closed_on_mirror_drift",
        "fail_closed_on_live_route_drift"
      ],
      "properties": {
        "json_validation_commands": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 2
        },
        "required_validator": { "type": "string" },
        "connector_fallback_allowed": { "type": "boolean" },
        "markdown_mirror_validation_required": { "type": "boolean" },
        "fail_closed_on_mirror_drift": { "type": "boolean" },
        "fail_closed_on_live_route_drift": { "type": "boolean" }
      }
    },
    "artifact_routes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_file",
        "schema_file",
        "validator_script",
        "current_state_mirror",
        "next_action_mirror",
        "decision_locks_mirror",
        "context_index_mirror",
        "phase_ledger_history",
        "roadmap_authority",
        "readme",
        "anti_corruption_contract"
      ],
      "properties": {
        "state_file": { "type": "string", "const": "ACTIVE_CONTEXT_STATE.json" },
        "schema_file": { "type": "string", "const": "ACTIVE_CONTEXT_SCHEMA.json" },
        "validator_script": { "type": "string", "const": "scripts/validate_active_context_state.py" },
        "current_state_mirror": { "type": "string", "const": "CURRENT_STATE.md" },
        "next_action_mirror": { "type": "string", "const": "NEXT_ACTION.md" },
        "decision_locks_mirror": { "type": "string", "const": "DECISION_LOCKS.md" },
        "context_index_mirror": { "type": "string", "const": "CONTEXT_INDEX.md" },
        "phase_ledger_history": { "type": "string", "const": "ARIS_PHASE_LEDGER.md" },
        "roadmap_authority": { "type": "string", "const": "ROADMAP_CANONICAL.md" },
        "readme": { "type": "string", "const": "README.md" },
        "anti_corruption_contract": { "type": "string", "const": "ACTIVE_CONTEXT_ANTI_CORRUPTION_CONTRACT.md" }
      }
    },
    "history_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "governance_repairs",
        "latest_execution_phase",
        "previous_execution_phase",
        "ledger_mode",
        "markdown_mirrors_are_non_authoritative"
      ],
      "properties": {
        "governance_repairs": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "latest_execution_phase": { "type": "string" },
        "previous_execution_phase": { "type": "string" },
        "ledger_mode": { "type": "string" },
        "markdown_mirrors_are_non_authoritative": { "type": "boolean", "const": true }
      }
    },
    "last_transition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transition_type",
        "from_phase",
        "to_phase",
        "decision",
        "verified_via",
        "proof_source"
      ],
      "properties": {
        "transition_type": { "type": "string" },
        "from_phase": { "type": "string" },
        "to_phase": { "type": "string" },
        "decision": { "type": "string", "enum": ["pass", "fail", "blocked", "warn"] },
        "verified_via": { "type": "string" },
        "proof_source": { "type": "string" }
      }
    },
    "required_update_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "current_route_must_be_written_in_json_first",
        "markdown_mirror_drift_policy",
        "ledger_drift_policy",
        "live_state_source_drift_policy",
        "on_any_transition"
      ],
      "properties": {
        "current_route_must_be_written_in_json_first": { "type": "boolean", "const": true },
        "markdown_mirror_drift_policy": { "type": "string" },
        "ledger_drift_policy": { "type": "string" },
        "live_state_source_drift_policy": { "type": "string" },
        "on_any_transition": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 5
        }
      }
    },
    "drift_signals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_vs_github_drift",
        "markdown_mirror_drift",
        "ledger_live_route_drift",
        "json_state_mismatch",
        "connector_fallback_required_if_cli_dns_or_ssh_fails"
      ],
      "properties": {
        "local_vs_github_drift": { "type": "string" },
        "markdown_mirror_drift": { "type": "string" },
        "ledger_live_route_drift": { "type": "string" },
        "json_state_mismatch": { "type": "string" },
        "connector_fallback_required_if_cli_dns_or_ssh_fails": { "type": "boolean" }
      }
    }
  }
}
